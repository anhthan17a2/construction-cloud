# ─── Database ──────────────────────────────────────────────
# Local dev: đổi sang PostgreSQL URL từ Neon sau khi tạo database
# Hoặc dùng local PostgreSQL: postgresql://postgres:password@localhost:5432/construction_cloud
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/construction_cloud"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/construction_cloud"

# ─── Auth.js ──────────────────────────────────────────────
AUTH_SECRET="construction-cloud-secret-key-min-32-chars-ok"
AUTH_URL="http://localhost:3000"

# ─── Google OAuth (set real values to enable Google login) ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AWS S3 (mock values for local dev) ───────────────────
AWS_ACCESS_KEY_ID="mock-key"
AWS_SECRET_ACCESS_KEY="mock-secret"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="construction-cloud-dev"

# ─── Pusher (mock values for local dev) ───────────────────
PUSHER_APP_ID="mock"
PUSHER_KEY="mock"
PUSHER_SECRET="mock"
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY="mock"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ConstructionCloud"
